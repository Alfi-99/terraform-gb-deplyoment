# =============================================================================
# File-file yang TIDAK boleh masuk ke Git
# =============================================================================

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files berisi secrets
terraform.tfvars
*.auto.tfvars

# Terraform cache dan lock
.terraform/
.terraform.lock.hcl

# Lambda build artifacts
lambda/layer.zip
lambda/post-handler.zip
lambda/get-handler.zip
lambda/layer/nodejs/node_modules/

# AWS credentials
.aws/credentials
*.pem
*.key

# Environment files
.env
.env.*
!.env.example

# OS generated files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE files
.vscode/settings.json
.idea/
*.sublime-project

# Logs
*.log
logs/

# Node modules
node_modules/

# Coverage reports
coverage/
